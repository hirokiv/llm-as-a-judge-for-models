# Secret Template
#
# IMPORTANT: Do NOT commit actual secrets to git!
# This is a template file. Create actual secrets using kubectl:
#
# kubectl create secret generic llm-judge-secrets \
#   --from-literal=azure-openai-api-key='YOUR_KEY' \
#   --from-literal=azure-openai-endpoint='YOUR_ENDPOINT' \
#   --from-literal=databricks-server-hostname='YOUR_HOSTNAME' \
#   --from-literal=databricks-http-path='YOUR_PATH' \
#   --from-literal=databricks-access-token='YOUR_TOKEN' \
#   --namespace=production
#
# Or use a Secret Manager (recommended):
# - AWS Secrets Manager
# - Azure Key Vault
# - Google Secret Manager
# - HashiCorp Vault

apiVersion: v1
kind: Secret
metadata:
  name: llm-judge-secrets
  labels:
    app: llm-judge-api
type: Opaque
stringData:
  # Azure OpenAI (本番環境)
  azure-openai-api-key: "REPLACE_WITH_ACTUAL_KEY"
  azure-openai-endpoint: "https://your-resource.openai.azure.com"

  # Databricks (本番環境)
  databricks-server-hostname: "your-workspace.cloud.databricks.com"
  databricks-http-path: "/sql/1.0/warehouses/your-warehouse-id"
  databricks-access-token: "REPLACE_WITH_ACTUAL_TOKEN"

  # OpenAI (オプション - 開発環境用)
  openai-api-key: ""

  # Supabase (オプション - ステージング環境用)
  supabase-url: ""
  supabase-key: ""
