# ==========================================
# 環境変数テンプレート（MVP構成）
# ==========================================
# このファイルを .env にコピーして実際の値を設定してください。
# コマンド: cp .env.example .env

# ==========================================
# アプリケーション設定
# ==========================================
ENVIRONMENT=development  # development | staging | production
DEBUG=True
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ==========================================
# データベース設定
# ==========================================
# プロバイダー選択
DB_PROVIDER=supabase  # supabase | databricks

# Supabase（開発環境）
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Databricks（本番環境）
# DATABRICKS_SERVER_HOSTNAME=xxxxx.cloud.databricks.com
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxx
# DATABRICKS_ACCESS_TOKEN=dapi...

# ==========================================
# LLM Provider設定
# ==========================================
# プロバイダー選択
LLM_PROVIDER=openai  # openai | azure_openai

# OpenAI
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure OpenAI（オプション）
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ==========================================
# MLflow設定
# ==========================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=llm-judge-evaluations
MLFLOW_ARTIFACT_LOCATION=./mlruns

# ==========================================
# 認証・セキュリティ設定
# ==========================================
# JWT Secret Key (本番環境では必ず変更すること!)
# 生成コマンド: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-replace-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# 冪等性チェッカー設定
# ==========================================
# 実行回数（同一入力に対する評価回数）
IDEMPOTENCY_NUM_RUNS=3
# 一貫性の閾値（0.0-1.0、1.0が完全一致）
IDEMPOTENCY_VARIANCE_THRESHOLD=0.9

# ==========================================
# API設定
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True  # 本番環境ではFalseに設定

# ==========================================
# 機能フラグ
# ==========================================
ENABLE_IDEMPOTENCY_CHECK=True
ENABLE_RUBRIC_EVALUATION=True
ENABLE_AUDIT_LOG=True

# ==========================================
# セットアップガイド
# ==========================================
# 1. このファイルを .env にコピー:
#    cp .env.example .env
#
# 2. 必須項目を設定:
#    - SUPABASE_URL, SUPABASE_KEY (Supabaseコンソールから取得)
#    - OPENAI_API_KEY (https://platform.openai.com/api-keys)
#    - JWT_SECRET_KEY (本番環境では必ず変更: openssl rand -hex 32)
#
# 3. ローカル開発環境の場合（Supabase CLI使用）:
#    - SUPABASE_URL=http://127.0.0.1:54321
#    - SUPABASE_KEY=<supabase start で表示されるanon key>
#    - MLFLOW_TRACKING_URI=http://127.0.0.1:5000
#
# 4. 環境確認:
#    make check-env
#
# 5. MLflowサーバー起動（別ターミナル）:
#    make mlflow
#
# 6. Supabaseローカル起動（別ターミナル）:
#    supabase start
#
# 7. アプリケーション起動:
#    make run
#
# 詳細: docs/user/quickstart.md を参照
#
# ==========================================
# 本番環境デプロイ前のチェックリスト
# ==========================================
# [ ] ENVIRONMENT=production に変更
# [ ] DEBUG=False に変更
# [ ] JWT_SECRET_KEY を安全な値に変更
# [ ] OPENAI_API_KEY を本番用キーに変更
# [ ] SUPABASE_URL/KEY を本番環境の値に変更（または DATABRICKS_* に変更）
# [ ] LOG_LEVEL=WARNING または ERROR に変更
# [ ] API_RELOAD=False に変更
# [ ] .env ファイルが .gitignore に含まれていることを確認
