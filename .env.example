# LLM Provider
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Database - Supabase (Development)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database - Databricks (Production)
# DATABRICKS_TOKEN=dapi...
# DATABRICKS_HOST=https://xxxxx.cloud.databricks.com
# DATABRICKS_CATALOG=enterprise_ai_monitor

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=llm-judge-evaluations
# MLFLOW_BACKEND_STORE_URI=postgresql://user:password@localhost:5432/mlflow
# MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://your-bucket/mlflow-artifacts

# Authentication
JWT_SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=LLM-as-a-Judge
APP_VERSION=1.0.0
ENVIRONMENT=development  # development | staging | production
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json  # json | text

# Database Provider
DB_PROVIDER=supabase  # supabase | databricks

# LLM Provider
LLM_PROVIDER=openai  # openai | azure_openai

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Cache
CACHE_ENABLED=True
CACHE_TTL_SECONDS=300

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# Worker Configuration
MAX_WORKERS=10
MAX_CONCURRENT_REQUESTS=10

# Timeouts
REQUEST_TIMEOUT_SECONDS=30
LLM_API_TIMEOUT_SECONDS=60

# Idempotency
IDEMPOTENCY_CHECK_RUNS=3
IDEMPOTENCY_VARIANCE_THRESHOLD=0.9

# Test Mode
TEST_MODE=False
STUB_MODE=False
