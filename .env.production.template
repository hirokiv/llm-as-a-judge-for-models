# Production Environment Configuration Template
#
# IMPORTANT:
# - DO NOT commit this file with actual secrets!
# - Use Kubernetes Secrets or Secret Manager for production
# - This is a template for documentation purposes only

# ==================== Environment ====================
ENVIRONMENT=production

# ==================== LLM Provider (Azure OpenAI for Production) ====================
LLM_PROVIDER=azure_openai

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=REPLACE_WITH_ACTUAL_KEY
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# OpenAI (Fallback - Optional)
# OPENAI_API_KEY=sk-...

# ==================== Database (Databricks for Production) ====================
DB_PROVIDER=databricks

# Databricks Configuration
DATABRICKS_SERVER_HOSTNAME=your-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_ACCESS_TOKEN=REPLACE_WITH_ACTUAL_TOKEN

# Databricks Schema
DATABRICKS_CATALOG=llm_judge_prod
DATABRICKS_SCHEMA=evaluations

# ==================== MLflow ====================
MLFLOW_TRACKING_URI=https://mlflow.production.example.com
MLFLOW_EXPERIMENT_NAME=llm-judge-evaluations-production

# MLflow Databricks Integration (Optional)
# MLFLOW_TRACKING_USERNAME=your-username
# MLFLOW_TRACKING_PASSWORD=your-password

# ==================== Logging ====================
LOG_LEVEL=INFO
DEBUG=False

# Structured logging format
LOG_FORMAT=json

# ==================== Security ====================
# JWT Secret (Generate with: openssl rand -hex 32)
JWT_SECRET_KEY=REPLACE_WITH_ACTUAL_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys (comma-separated)
API_KEYS=REPLACE_WITH_ACTUAL_API_KEYS

# ==================== Performance ====================
# Timeouts (seconds)
LLM_TIMEOUT=60
DATABASE_TIMEOUT=30
HTTP_CLIENT_TIMEOUT=30

# ==================== CORS ====================
ALLOWED_ORIGINS=https://app.production.example.com

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=100

# ==================== Monitoring ====================
# Prometheus metrics
METRICS_ENABLED=True

# Sentry (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# ==================== Feature Flags ====================
# Idempotency check
ENABLE_IDEMPOTENCY_CHECK=True
IDEMPOTENCY_NUM_RUNS=3

# Rubric evaluation
ENABLE_RUBRIC_EVALUATION=False

# ==================== Storage (Optional) ====================
# Azure Blob Storage (for artifacts)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
# AZURE_STORAGE_CONTAINER_NAME=llm-judge-artifacts

# AWS S3 (alternative)
# AWS_ACCESS_KEY_ID=YOUR_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET
# AWS_S3_BUCKET=llm-judge-artifacts
# AWS_REGION=us-east-1
